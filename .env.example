# Animal Adventure Backend Environment Configuration
# Copy this file to .env and adjust values for your local setup.
# Do NOT commit .env to source control.

# --- FastAPI server ---
# Host and port for the uvicorn process. Nginx proxies to this address.
APP_HOST=127.0.0.1
APP_PORT=8000

# Set to "true" to enable FastAPI debug mode and auto-reload.
APP_DEBUG=false

# --- SQLite database ---
# Path to the SQLite database file, relative to the project root.
DATABASE_PATH=data/animal_adventure.sqlite3

# --- Log file paths ---
# All paths are relative to the project root.
LOG_APP=logs/app.log
LOG_ERROR=logs/error.log
LOG_PLAYER_EVENTS=logs/player-events.log
LOG_RESOURCE=logs/resource.log

# Log level for the application logger (DEBUG, INFO, WARNING, ERROR, CRITICAL).
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated list of allowed origins for browser clients.
# Default allows the Nginx frontend on port 8080.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
